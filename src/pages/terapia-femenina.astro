---
import MainLayout from "@/layouts/MainLayout.astro";
import ameliaProfile from "@/assets/images/amelia-women-therapy.jpeg";

const therapeuticGoals = [
  {
    number: "01",
    title: "Pensamientos automáticos",
    description: "Identificar pensamientos automáticos que generan culpa, ansiedad o sensación de insuficiencia.",
  },
  {
    number: "02",
    title: "Mandatos y creencias",
    description: "Cuestionar mandatos sociales y creencias rígidas que afectan la autoestima y el autocuidado.",
  },
  {
    number: "03",
    title: "Regulación emocional",
    description: "Desarrollar habilidades para el manejo del estrés, la regulación emocional y la toma de decisiones.",
  },
  {
    number: "04",
    title: "Límites sanos",
    description: "Fortalecer la capacidad de poner límites sanos en las relaciones.",
  },
  {
    number: "05",
    title: "Autocompasión",
    description: "Promover una relación más compasiva con el propio cuerpo, las emociones y las etapas de vida.",
  },
];

const signals = [
  "Ansiedad frecuente, preocupación excesiva o dificultad para descansar",
  "Agotamiento emocional o sensación de no poder más",
  "Baja autoestima, autocrítica intensa o dificultad para valorarte",
  "Dificultad para poner límites en relaciones personales o laborales",
  "Momentos de cambio: maternidad, separación, duelo, transiciones laborales",
  "Deseo de conocerte mejor y construir una vida más alineada con tus valores",
];

const faqs = [
  {
    q: "¿Qué es la terapia psicológica para mujeres?",
    a: "Es un acompañamiento especializado que reconoce los factores biológicos, sociales y relacionales propios de la experiencia femenina: presiones de género, autoexigencia, agotamiento emocional, dificultad para poner límites y baja autoestima. Trabaja desde un enfoque cognitivo-conductual basado en evidencia.",
  },
  {
    q: "¿Cómo sé si necesito terapia psicológica?",
    a: "Podría ser útil si experimentás ansiedad frecuente, agotamiento emocional, dificultad para poner límites, baja autoestima, sensación de no poder con todo, o si atravesás una etapa de cambio o crisis emocional. No es necesario estar en crisis para iniciar un proceso terapéutico.",
  },
  {
    q: "¿Las sesiones son online o presenciales?",
    a: "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica. La modalidad se acuerda según lo que mejor se adapte a cada persona.",
  },
];

const siteUrl = "https://psicologaameliareyes.com";
const pageUrl = `${siteUrl}/salud-mental-femenina`;
const imageUrl = `${siteUrl}${ameliaProfile.src}`;

const jsonLdService = {
  "@context": "https://schema.org",
  "@type": ["Service", "MedicalBusiness"],
  "name": "Salud Mental Femenina en Costa Rica",
  "alternateName": "Terapia psicológica para mujeres Costa Rica",
  "description": "Terapia psicológica especializada para mujeres en Costa Rica. Abordaje de ansiedad, autoestima, estrés y agotamiento emocional con enfoque cognitivo-conductual. Atención presencial en Heredia y sesiones online.",
  "url": pageUrl,
  "image": imageUrl,
  "provider": {
    "@type": ["Person", "Psychologist"],
    "name": "Amelia Reyes",
    "jobTitle": "Psicóloga Clínica",
    "description": "Psicóloga clínica especializada en salud mental femenina y bienestar emocional en Costa Rica.",
    "url": siteUrl,
    "telephone": "+50660587256",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Heredia",
      "addressCountry": "CR",
    },
  },
  "areaServed": [
    { "@type": "Country", "name": "Costa Rica" },
    { "@type": "City", "name": "Heredia" },
    { "@type": "City", "name": "San José" },
  ],
  "serviceType": "Psicología Clínica Femenina",
  "audience": { "@type": "Audience", "audienceType": "Mujeres adultas" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "CRC",
    "url": "https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Femenina",
  },
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": `${siteUrl}/#servicios` },
    { "@type": "ListItem", "position": 3, "name": "Salud Mental Femenina", "item": pageUrl },
  ],
};

const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es la terapia psicológica para mujeres?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Es un acompañamiento especializado que reconoce los factores biológicos, sociales y relacionales propios de la experiencia femenina: presiones de género, autoexigencia, agotamiento emocional, dificultad para poner límites y baja autoestima. Trabaja desde un enfoque cognitivo-conductual basado en evidencia.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Cómo sé si necesito terapia psicológica?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Podría ser útil si experimentás ansiedad frecuente, agotamiento emocional, dificultad para poner límites, baja autoestima, sensación de no poder con todo, o si atravesás una etapa de cambio o crisis emocional. No es necesario estar en crisis para iniciar un proceso terapéutico.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Las sesiones son online o presenciales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica.",
      },
    },
  ],
};

const title = "Salud Mental Femenina en Costa Rica | Psicóloga Amelia Reyes | Heredia y Online";
const description = "Terapia psicológica especializada para mujeres en Costa Rica. Trabajá la ansiedad, autoestima, estrés y agotamiento emocional con enfoque cognitivo-conductual. Atención presencial en Heredia y sesiones online con la Psicóloga Amelia Reyes.";
---

<MainLayout title={title} description={description} image={ameliaProfile.src}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdService)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />

  {/* Google Fonts */}
  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap"
  />

  <div class="font-dm-sans bg-[#F4F0EC] text-[#183942]">

    {/* ===== HERO ===== */}
    <section
      class="grid grid-cols-2 relative overflow-hidden min-h-130 max-[1100px]:min-h-120 max-[900px]:grid-cols-1 max-[900px]:h-auto"
      aria-label="Salud Mental Femenina en Costa Rica"
    >
      {/* Hero Left */}
      <div class="flex flex-col justify-center py-24 pr-12 pl-[5vw] pt-24 relative z-10 overflow-hidden max-[900px]:px-6 max-[900px]:pt-20 max-[900px]:pb-12">
        {/* Breadcrumb */}
        <nav aria-label="Ruta de navegación" class="flex items-center gap-2 text-xs text-[#8aabb3] mb-8">
          <a href="/" class="hover:text-[#183942] transition-colors">Inicio</a>
          <span class="text-[#ccc]">/</span>
          <a href="/#servicios" class="hover:text-[#183942] transition-colors">Servicios</a>
          <span class="text-[#ccc]">/</span>
          <span class="text-[#183942] font-medium" aria-current="page">Salud Mental Femenina</span>
        </nav>

        {/* Tag */}
        <div class="inline-block text-[0.7rem] font-medium tracking-[0.18em] uppercase text-[#CC8989] border border-[#CC8989] px-[0.9rem] py-[0.35rem] rounded-sm mb-8 w-fit">
          Servicio especializado
        </div>

        {/* Heading */}
        <h1 class="font-cormorant font-light leading-[1.05] text-[#183942] mb-7" style="font-size: clamp(3rem, 6vw, 5.5rem)">
          Salud Mental<br />
          <em class="italic text-[#CC8989]">Femenina</em><br />
          <span class="text-[0.75em] text-[#183942]">en Costa Rica</span>
        </h1>

        {/* Subheading */}
        <p class="text-base font-light text-[#4a6068] leading-[1.7] max-w-110 mb-12">
          Un acompañamiento para mujeres que buscan construir una relación más equilibrada consigo mismas, con sus vínculos y con las demandas del entorno. Presencial en{" "}
          <strong class="font-medium text-[#183942]">Heredia</strong> y{" "}
          <strong class="font-medium text-[#183942]">online</strong> para toda Costa Rica.
        </p>

        {/* Actions */}
        <div class="flex items-center gap-8 flex-wrap">
          <a
            href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Femenina"
            class="inline-flex items-center gap-[0.6rem] bg-[#183942] text-[#F4F0EC] text-[0.8rem] font-medium tracking-widest uppercase px-8 py-4 no-underline transition-colors duration-250 hover:bg-[#CC8989]"
            aria-label="Agendar cita de Salud Mental Femenina por WhatsApp"
          >
            Agenda tu cita
            <svg class="w-3.5 h-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="#acompanamiento"
            class="text-[0.8rem] font-normal tracking-[0.08em] text-[#CC8989] no-underline border-b border-[#CC8989] pb-0.5 transition-opacity duration-200 hover:opacity-65"
          >
            Cómo te acompaño
          </a>
        </div>
      </div>

      {/* Hero Right */}
      <div class="relative bg-[#2d1f1f] overflow-hidden max-[900px]:h-[55vw] max-[900px]:min-h-65" aria-hidden="true">
        <img
          src={ameliaProfile.src}
          alt=""
          width={ameliaProfile.width}
          height={ameliaProfile.height}
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover object-[center_40%] opacity-50 mix-blend-luminosity"
        />
        {/* Gradient overlay */}
        <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(135deg, #2d1f1f 0%, transparent 60%)"></div>
      </div>
    </section>

    {/* Line divider */}
    <div class="h-px m-0" style="background: linear-gradient(to right, #CC8989 30%, transparent)"></div>

    {/* ===== CONTEXTO ===== */}
    <section id="acompanamiento" class="py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="contexto-heading">
      <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#CC8989] mb-5">
        Enfoque terapéutico
      </div>

      <div class="grid grid-cols-2 gap-0 mt-16 max-[900px]:grid-cols-1">
        {/* Left */}
        <div class="pr-16 border-r border-[#d9d3cc] max-[900px]:pr-0 max-[900px]:border-r-0 max-[900px]:border-b max-[900px]:border-[#d9d3cc] max-[900px]:pb-12 max-[900px]:mb-12">
          <h2
            id="contexto-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#183942] mb-7"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            ¿Qué es la terapia psicológica para mujeres?
          </h2>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            La salud mental femenina reconoce que las mujeres enfrentan, a lo largo de su vida, múltiples transiciones biológicas, sociales y relacionales que impactan su bienestar emocional: cambios hormonales, presiones de género, exigencias laborales y familiares, maternidad, duelos, rupturas, experiencias de violencia, entre otros.
          </p>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            La evidencia muestra que estos factores pueden influir en una mayor prevalencia de ansiedad, depresión, trastornos del estado de ánimo y altos niveles de autoexigencia y culpa.
          </p>
          <blockquote class="border-l-2 border-[#CC8989] py-6 pl-8 mt-10">
            <p class="font-cormorant text-[1.25rem] italic font-normal text-[#183942] leading-[1.55] mb-3">
              "Muchas mujeres han aprendido creencias que refuerzan el sacrificio personal o la necesidad de cumplir con ideales inalcanzables. Estas creencias sostienen el agotamiento y la postergación de las propias necesidades."
            </p>
            <footer class="text-[0.75rem] font-light tracking-[0.08em] text-[#a08080] uppercase">
              — Psicóloga Amelia Reyes
            </footer>
          </blockquote>
        </div>

        {/* Right */}
        <div class="pl-16 max-[900px]:pl-0">
          <h3 class="font-cormorant text-[1.4rem] font-medium text-[#183942] mb-6">
            ¿Cuándo buscar terapia psicológica?
          </h3>
          <ul class="list-none p-0 m-0" role="list">
            {signals.map((item, i) => (
              <li class="flex items-start gap-4 py-[0.9rem] border-b border-[#e8e2db] text-[0.9rem] font-light text-[#4a6068] leading-normal last:border-b-0">
                <span class="font-cormorant text-[0.85rem] text-[#CC8989] italic shrink-0 pt-px">
                  {String(i + 1).padStart(2, "0")}.
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* ===== OBJETIVOS ===== */}
    <section class="bg-[#2d1f1f] py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="goals-heading">
      <div class="flex items-end justify-between gap-8 mb-14 flex-wrap">
        <div>
          <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#c4a0a0] mb-5">
            Acompañamiento
          </div>
          <h2
            id="goals-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#f5eded]"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            El proceso terapéutico busca
          </h2>
        </div>
        <p class="text-[0.9rem] font-light text-[#a08080] max-w-[320px] leading-[1.6]">
          Objetivos concretos para construir una relación más equilibrada contigo misma.
        </p>
      </div>

      <div
        data-goals-grid
        class="grid border-t border-[#4a2e2e]"
        style="grid-template-columns: repeat(5, 1fr)"
        role="list"
      >
        {therapeuticGoals.map((goal, i) => (
          <div
            class="p-8 border-r border-b border-[#4a2e2e] last:border-r-0 max-[1100px]:nth-col-3-no-border max-[640px]:even:border-r-0"
            role="listitem"
          >
            <span class="font-cormorant text-[0.9rem] italic text-[#CC8989] mb-5 block">
              {goal.number}
            </span>
            <div class="text-[0.85rem] font-medium text-[#f0dede] mb-3 leading-[1.3]">
              {goal.title}
            </div>
            <p class="text-[0.78rem] font-light text-[#9a7070] leading-[1.65]">
              {goal.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    {/* ===== LOCAL STRIP ===== */}
    <div
      class="bg-[#eae5df] py-10 px-[5vw] flex items-center gap-8 flex-wrap max-[640px]:py-8 max-[640px]:px-6 max-[640px]:gap-4"
      aria-label="Disponibilidad"
    >
      <span class="text-[0.68rem] font-medium tracking-[0.18em] uppercase text-[#CC8989] shrink-0">
        Heredia · Online · Costa Rica
      </span>
      <div class="flex-1 h-px bg-[#d9d3cc]" aria-hidden="true"></div>
      <p class="text-[0.83rem] font-light text-[#4a6068] leading-[1.65] max-w-160">
        Si buscás una psicóloga para mujeres en Heredia, ofrezco atención presencial en consultorio y sesiones online para todo el país. Confidencialidad, respeto y acompañamiento profesional, sin juicios y adaptado al ritmo de cada mujer.
      </p>
    </div>

    {/* ===== FAQ ===== */}
    <section class="bg-white py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="faq-heading">
      <div class="grid gap-16 items-start max-[800px]:grid-cols-1 max-[800px]:gap-8" style="grid-template-columns: 280px 1fr">
        <div>
          <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#CC8989] mb-5">
            FAQ
          </div>
          <h2
            id="faq-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#183942]"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            Preguntas frecuentes
          </h2>
        </div>

        <dl class="border-t border-[#e8e2db]">
          {faqs.map((item) => (
            <div class="faq-item border-b border-[#e8e2db]" data-faq>
              <button
                class="w-full bg-transparent border-none py-6 flex items-center justify-between gap-4 cursor-pointer text-left font-dm-sans text-[0.9rem] font-medium text-[#183942] leading-[1.4]"
                aria-expanded="false"
              >
                <span>{item.q}</span>
                <svg
                  class="shrink-0 w-4 h-4 text-[#CC8989] transition-transform duration-300"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <dd class="faq-answer hidden pb-6 text-[0.85rem] font-light text-[#4a6068] leading-[1.75]">
                {item.a}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="bg-[#2d1f1f] py-24 px-[5vw] relative overflow-hidden max-[640px]:py-16 max-[640px]:px-6" aria-labelledby="cta-heading">
      {/* Decorative circles */}
      <div class="absolute rounded-full pointer-events-none border border-[#4a2e2e]" style="right: -80px; top: -80px; width: 400px; height: 400px;" aria-hidden="true"></div>
      <div class="absolute rounded-full pointer-events-none border border-[#4a2e2e]" style="right: -40px; top: -40px; width: 280px; height: 280px;" aria-hidden="true"></div>

      <div class="relative z-10 max-w-175">
        <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#c4a0a0] mb-6">
          Próximo paso
        </div>
        <h2
          id="cta-heading"
          class="font-cormorant font-light leading-[1.15] text-[#f5eded] mb-6"
          style="font-size: clamp(2rem, 4vw, 3.5rem)"
        >
          ¿Querés iniciar tu<br />
          <em class="italic text-[#c4a0a0]">proceso terapéutico?</em>
        </h2>
        <p class="text-[0.9rem] font-light text-[#a08080] leading-[1.75] max-w-130 mb-12">
          La terapia cognitivo-conductual cuenta con sólida evidencia en el tratamiento de la ansiedad, la depresión y el estrés crónico, y resulta especialmente útil para acompañar a mujeres que buscan construir una relación más equilibrada consigo mismas, con sus vínculos y con las demandas del entorno.
        </p>
        <a
          href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Femenina"
          class="inline-flex items-center gap-[0.7rem] bg-[#F4F0EC] text-[#2d1f1f] text-[0.78rem] font-medium tracking-[0.12em] uppercase px-9 py-4 no-underline transition-colors duration-250 hover:bg-[#CC8989] hover:text-[#F4F0EC]"
          aria-label="Agendar cita de Salud Mental Femenina con Psicóloga Amelia Reyes por WhatsApp"
        >
          Quiero agendar mi cita
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </div>

  {/* Minimal CSS for things Tailwind can't express inline */}
  <style>
    .font-cormorant { font-family: 'Cormorant Garamond', Georgia, serif; }
    .font-dm-sans   { font-family: 'DM Sans', sans-serif; }

    /* FAQ open state */
    .faq-item.open .faq-answer { display: block; }
    .faq-item.open button svg  { transform: rotate(45deg); }
    .faq-item.open button      { aria-expanded: true; }

    /* Goals grid responsive overrides */
    @media (max-width: 1100px) {
      [data-goals-grid] {
        grid-template-columns: repeat(3, 1fr) !important;
      }
      [data-goals-grid] > *:nth-child(3n) {
        border-right: none;
      }
    }
    @media (max-width: 640px) {
      [data-goals-grid] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      [data-goals-grid] > *:nth-child(2n) {
        border-right: none;
      }
    }
  </style>

  <script>
    // FAQ accordion
    document.querySelectorAll('[data-faq]').forEach((item) => {
      const btn = item.querySelector('button');
      btn?.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('[data-faq]').forEach((el) => {
          el.classList.remove('open');
          el.querySelector('button')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
</MainLayout>