---
import MainLayout from "@/layouts/MainLayout.astro";
import ameliaProfile from "@/assets/images/amelia-women-therapy.jpeg";

const topicCards = [
  {
    number: "01",
    title: "Duelos en la maternidad",
    description:
      "La evidencia nos muestra que este periodo no es un camino lineal de felicidad. Es un tiempo donde pueden aparecer distintos tipos de duelos: el duelo perinatal o neonatal, el duelo por una fertilidad que no llega, el duelo de pareja al redefinir la relación después de la llegada de un hijo o hija, y el duelo por la mujer que ya no soy. Estos procesos pueden generar síntomas de ansiedad, depresión o estrés postraumático, y requieren un acompañamiento respetuoso, sin juicios y basado en evidencia.",
  },
  {
    number: "02",
    title: "Fertilidad y tratamientos",
    description:
      "Muchas mujeres atraviesan procesos de infertilidad o acompañan tratamientos de fertilización asistida. Estos procesos suelen implicar frustración, cansancio emocional, incertidumbre y una montaña rusa de expectativas. Desde la TCC se acompaña a las mujeres a manejar la ansiedad anticipatoria, la autocrítica, el miedo al fracaso y el desgaste emocional que puede aparecer en cada etapa del proceso.",
  },
  {
    number: "03",
    title: "Postparto y dificultades emocionales",
    description:
      "Después del parto también pueden presentarse dificultades emocionales significativas. La depresión posparto, la ansiedad posparto, la psicosis posparto y el llamado baby blues son realidades clínicas que requieren acompañamiento oportuno. La TCC cuenta con evidencia sólida para disminuir síntomas de depresión y ansiedad en el periodo perinatal.",
  },
  {
    number: "04",
    title: "Una mirada realista de la maternidad",
    description:
      "En este acompañamiento, no romantizamos la maternidad. Sabemos que no siempre hay un vínculo inmediato con el bebé, que pueden aparecer sentimientos ambivalentes, cansancio extremo, culpa, enojo o tristeza. Desde la TCC se trabajan creencias rígidas promoviendo una mirada más flexible, respetuosa y compasiva hacia las decisiones individuales y las realidades de cada familia.",
  },
];

const signals = [
  "Tristeza persistente, llanto frecuente o sensación de vacío después del parto",
  "Ansiedad intensa, miedos exagerados o pensamientos intrusivos sobre el bebé",
  "Dificultad para vincularte con tu bebé o sentirte 'buena mamá'",
  "Agotamiento emocional durante el embarazo o la crianza",
  "Duelo perinatal, pérdida gestacional o duelo por fertilidad",
  "Deseo de prepararte emocionalmente antes de la llegada del bebé",
];

const faqs = [
  {
    q: "¿Qué es la psicología materna?",
    a: "La psicología materna acompaña a las mujeres durante el embarazo, el posparto y las distintas etapas de la crianza. Trabaja el bienestar emocional, la identidad materna, los duelos, la ansiedad, la depresión posparto y los cambios relacionales que ocurren en esta etapa.",
  },
  {
    q: "¿Qué es la depresión posparto y cómo se trata?",
    a: "La depresión posparto es un trastorno del estado de ánimo que puede aparecer después del parto. Se caracteriza por tristeza persistente, agotamiento, dificultad para vincularse con el bebé, ansiedad o sentimientos de culpa. La Terapia Cognitivo-Conductual (TCC) es uno de los enfoques con mayor evidencia para su tratamiento.",
  },
  {
    q: "¿Las sesiones son online o presenciales?",
    a: "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica. La modalidad se acuerda según las necesidades y posibilidades de cada mamá.",
  },
  {
    q: "¿Puedo hacer terapia durante el embarazo?",
    a: "Sí. El embarazo es una etapa de grandes cambios emocionales e identitarios. Iniciar un proceso terapéutico durante el embarazo puede ayudarte a prepararte emocionalmente para la llegada del bebé, trabajar miedos, y fortalecer recursos para el posparto.",
  },
];

const siteUrl = "https://psicologaameliareyes.com";
const pageUrl = `${siteUrl}/terapia-materna`;
const imageUrl = `${siteUrl}${ameliaProfile.src}`;

const jsonLdService = {
  "@context": "https://schema.org",
  "@type": ["Service", "MedicalBusiness"],
  "name": "Salud Mental Materna en Costa Rica",
  "alternateName": "Psicóloga materna Costa Rica",
  "description": "Acompañamiento psicológico especializado durante el embarazo, postparto y crianza en Costa Rica. Apoyo en depresión posparto, duelo perinatal, ansiedad y fertilidad. Atención presencial en Heredia y sesiones online con la Psicóloga Amelia Reyes.",
  "url": pageUrl,
  "image": imageUrl,
  "provider": {
    "@type": ["Person", "Psychologist"],
    "name": "Amelia Reyes",
    "jobTitle": "Psicóloga Clínica",
    "description": "Psicóloga clínica especializada en salud mental materna en Costa Rica.",
    "url": siteUrl,
    "telephone": "+50660587256",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Heredia",
      "addressCountry": "CR",
    },
  },
  "areaServed": [
    { "@type": "Country", "name": "Costa Rica" },
    { "@type": "City", "name": "Heredia" },
    { "@type": "City", "name": "San José" },
  ],
  "serviceType": "Psicología Materna",
  "audience": { "@type": "Audience", "audienceType": "Madres y mujeres en etapa materna" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "CRC",
    "url": "https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Materna",
  },
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": `${siteUrl}/#servicios` },
    { "@type": "ListItem", "position": 3, "name": "Salud Mental Materna", "item": pageUrl },
  ],
};

const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es la psicología materna?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La psicología materna acompaña a las mujeres durante el embarazo, el posparto y las distintas etapas de la crianza. Trabaja el bienestar emocional, la identidad materna, los duelos, la ansiedad, la depresión posparto y los cambios relacionales que ocurren en esta etapa.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Qué es la depresión posparto y cómo se trata?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La depresión posparto es un trastorno del estado de ánimo que puede aparecer después del parto. Se caracteriza por tristeza persistente, agotamiento, dificultad para vincularse con el bebé, ansiedad o sentimientos de culpa. La Terapia Cognitivo-Conductual (TCC) es uno de los enfoques con mayor evidencia para su tratamiento.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Las sesiones de psicología materna son online o presenciales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Puedo hacer terapia durante el embarazo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. El embarazo es una etapa de grandes cambios emocionales e identitarios. Iniciar un proceso terapéutico durante el embarazo puede ayudar a prepararte emocionalmente para la llegada del bebé, trabajar miedos, y fortalecer recursos para el posparto.",
      },
    },
  ],
};

const title = "Salud Mental Materna en Costa Rica | Psicóloga Amelia Reyes | Heredia y Online";
const description = "Acompañamiento psicológico especializado durante el embarazo, postparto y crianza en Costa Rica. Apoyo en depresión posparto, duelo perinatal y ansiedad materna. Atención presencial en Heredia y sesiones online con la Psicóloga Amelia Reyes.";
---

<MainLayout title={title} description={description} image={ameliaProfile.src}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdService)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />

  <link
    slot="head"
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap"
  />

  <div class="font-dm-sans bg-[#F4F0EC] text-[#183942]">

    {/* ===== HERO ===== */}
    <section
      class="grid grid-cols-2 relative overflow-hidden min-h-130 max-[1100px]:min-h-120 max-[900px]:grid-cols-1 max-[900px]:h-auto"
      aria-label="Salud Mental Materna en Costa Rica"
    >
      {/* Hero Left */}
      <div class="flex flex-col justify-center py-24 pr-12 pl-[5vw] relative z-10 max-[900px]:px-6 max-[900px]:pt-20 max-[900px]:pb-12">
        {/* Breadcrumb */}
        <nav aria-label="Ruta de navegación" class="flex items-center gap-2 text-xs text-[#8aabb3] mb-8">
          <a href="/" class="hover:text-[#183942] transition-colors">Inicio</a>
          <span class="text-[#ccc]">/</span>
          <a href="/#servicios" class="hover:text-[#183942] transition-colors">Servicios</a>
          <span class="text-[#ccc]">/</span>
          <span class="text-[#183942] font-medium" aria-current="page">Salud Mental Materna</span>
        </nav>

        {/* Tag */}
        <div class="inline-block text-[0.7rem] font-medium tracking-[0.18em] uppercase text-[#CC8989] border border-[#CC8989] px-[0.9rem] py-[0.35rem] rounded-sm mb-8 w-fit">
          Servicio especializado
        </div>

        {/* Heading */}
        <h1 class="font-cormorant font-light leading-[1.05] text-[#183942] mb-7" style="font-size: clamp(3rem, 6vw, 5.5rem)">
          Salud Mental<br />
          <em class="italic text-[#CC8989]">Materna</em><br />
          <span class="text-[0.75em] text-[#183942]">en Costa Rica</span>
        </h1>

        {/* Subheading */}
        <p class="text-base font-light text-[#4a6068] leading-[1.7] max-w-110 mb-12">
          Duelo, fertilidad, postparto y una mirada realista de la maternidad. Acompañamiento presencial en{" "}
          <strong class="font-medium text-[#183942]">Heredia</strong> y{" "}
          <strong class="font-medium text-[#183942]">online</strong> para toda Costa Rica.
        </p>

        {/* Actions */}
        <div class="flex items-center gap-8 flex-wrap">
          <a
            href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Materna"
            class="inline-flex items-center gap-[0.6rem] bg-[#183942] text-[#F4F0EC] text-[0.8rem] font-medium tracking-widest uppercase px-8 py-4 no-underline transition-colors duration-250 hover:bg-[#CC8989]"
            aria-label="Agendar cita de Salud Mental Materna por WhatsApp"
          >
            Agenda tu cita
            <svg class="w-3.5 h-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="#areas"
            class="text-[0.8rem] font-normal tracking-[0.08em] text-[#CC8989] no-underline border-b border-[#CC8989] pb-0.5 transition-opacity duration-200 hover:opacity-65"
          >
            Áreas de acompañamiento
          </a>
        </div>
      </div>

      {/* Hero Right */}
      <div class="relative bg-[#1a2a1a] overflow-hidden max-[900px]:h-[65vw] max-[900px]:min-h-80" aria-hidden="true">
        <img
          src={ameliaProfile.src}
          alt=""
          width={ameliaProfile.width}
          height={ameliaProfile.height}
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover object-top opacity-[0.45] mix-blend-luminosity max-[900px]:object-[center_20%]"
        />
        <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(135deg, #1a2a1a 0%, transparent 60%)"></div>
      </div>
    </section>

    {/* Line divider */}
    <div class="h-px m-0" style="background: linear-gradient(to right, #CC8989 30%, transparent)"></div>

    {/* ===== CONTEXTO ===== */}
    <section id="acompanamiento" class="py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="contexto-heading">
      <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#CC8989] mb-5">
        Enfoque terapéutico
      </div>

      <div class="grid grid-cols-2 gap-0 mt-16 max-[900px]:grid-cols-1">
        {/* Left */}
        <div class="pr-16 border-r border-[#d9d3cc] max-[900px]:pr-0 max-[900px]:border-r-0 max-[900px]:border-b max-[900px]:border-[#d9d3cc] max-[900px]:pb-12 max-[900px]:mb-12">
          <h2
            id="contexto-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#183942] mb-7"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            ¿Qué es la salud mental materna?
          </h2>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            La salud mental materna abarca el bienestar emocional, psicológico y relacional de las mujeres durante el embarazo, el posparto y las distintas etapas de la crianza. La evidencia científica muestra que este periodo puede venir acompañado de cambios intensos a nivel hormonal, corporal, emocional y de identidad.
          </p>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            Desde el modelo cognitivo-conductual, entendemos que lo que una madre piensa acerca de sí misma, de su bebé y de su rol materno influye directamente en cómo se siente y en cómo actúa. Creencias como <em>"no soy suficiente"</em> o <em>"debería poder con todo"</em> pueden aumentar la culpa, la ansiedad y el agotamiento emocional.
          </p>
          <blockquote class="border-l-2 border-[#CC8989] py-6 pl-8 mt-10">
            <p class="font-cormorant text-[1.25rem] italic font-normal text-[#183942] leading-[1.55] mb-3">
              "La terapia cognitivo-conductual no busca enseñar cómo ser mamá ni imponer un modelo ideal de maternidad. Busca acompañar a cada mujer en su proceso único, validando su experiencia, su dolor, sus cambios y sus desafíos."
            </p>
            <footer class="text-[0.75rem] font-light tracking-[0.08em] text-[#a08080] uppercase">
              — Psicóloga Amelia Reyes
            </footer>
          </blockquote>
        </div>

        {/* Right */}
        <div class="pl-16 max-[900px]:pl-0">
          <h3 class="font-cormorant text-[1.4rem] font-medium text-[#183942] mb-6">
            ¿Cuándo buscar apoyo psicológico en la maternidad?
          </h3>
          <ul class="list-none p-0 m-0" role="list">
            {signals.map((item, i) => (
              <li class="flex items-start gap-4 py-[0.9rem] border-b border-[#e8e2db] text-[0.9rem] font-light text-[#4a6068] leading-normal last:border-b-0">
                <span class="font-cormorant text-[0.85rem] text-[#CC8989] italic shrink-0 pt-px">
                  {String(i + 1).padStart(2, "0")}.
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* ===== ÁREAS DE ACOMPAÑAMIENTO ===== */}
    <section id="areas" class="bg-[#1a2a1a] py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="areas-heading">
      <div class="flex items-end justify-between gap-8 mb-14 flex-wrap">
        <div>
          <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#9ab89a] mb-5">
            Acompañamiento
          </div>
          <h2
            id="areas-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#edf5ed]"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            Áreas de trabajo terapéutico
          </h2>
        </div>
        <p class="text-[0.9rem] font-light text-[#7a9a7a] max-w-[320px] leading-[1.6]">
          Un acompañamiento sin juicios, basado en evidencia y adaptado a cada etapa de la maternidad.
        </p>
      </div>

      <div data-areas-grid class="grid border-t border-[#2e4a2e]" style="grid-template-columns: repeat(4, 1fr)" role="list">
        {topicCards.map((card) => (
          <div class="area-item p-8 border-r border-b border-[#2e4a2e]" role="listitem">
            <span class="font-cormorant text-[0.9rem] italic text-[#CC8989] mb-5 block">
              {card.number}
            </span>
            <div class="text-[0.85rem] font-medium text-[#d4ead4] mb-3 leading-[1.3]">
              {card.title}
            </div>
            <p class="text-[0.78rem] font-light text-[#6a8a6a] leading-[1.65]">
              {card.description}
            </p>
          </div>
        ))}
      </div>
    </section>

    {/* ===== LOCAL STRIP ===== */}
    <div
      class="bg-[#eae5df] py-10 px-[5vw] flex items-center gap-8 flex-wrap max-[640px]:py-8 max-[640px]:px-6 max-[640px]:gap-4"
      aria-label="Disponibilidad"
    >
      <span class="text-[0.68rem] font-medium tracking-[0.18em] uppercase text-[#CC8989] shrink-0">
        Heredia · Online · Costa Rica
      </span>
      <div class="flex-1 h-px bg-[#d9d3cc]" aria-hidden="true"></div>
      <p class="text-[0.83rem] font-light text-[#4a6068] leading-[1.65] max-w-160">
        Si buscás una psicóloga materna en Heredia, ofrezco atención presencial en consultorio y sesiones online para todo el país. Confidencialidad, respeto y acompañamiento profesional, sin juicios y adaptado al ritmo de cada mamá.
      </p>
    </div>

    {/* ===== FAQ ===== */}
    <section class="bg-white py-20 px-[5vw] max-[640px]:py-14 max-[640px]:px-6" aria-labelledby="faq-heading">
      <div class="faq-grid grid gap-16 items-start">
        <div>
          <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#CC8989] mb-5">
            FAQ
          </div>
          <h2
            id="faq-heading"
            class="font-cormorant font-normal leading-[1.15] text-[#183942]"
            style="font-size: clamp(1.8rem, 3vw, 2.5rem)"
          >
            Preguntas frecuentes
          </h2>
        </div>

        <dl class="border-t border-[#e8e2db]">
          {faqs.map((item) => (
            <div class="faq-item border-b border-[#e8e2db]" data-faq>
              <button
                class="w-full bg-transparent border-none py-6 flex items-center justify-between gap-4 cursor-pointer text-left font-dm-sans text-[0.9rem] font-medium text-[#183942] leading-[1.4]"
                aria-expanded="false"
              >
                <span>{item.q}</span>
                <svg
                  class="shrink-0 w-4 h-4 text-[#CC8989] transition-transform duration-300"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <line x1="12" y1="5" x2="12" y2="19"/>
                  <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <dd class="faq-answer hidden pb-6 text-[0.85rem] font-light text-[#4a6068] leading-[1.75]">
                {item.a}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    {/* ===== CTA ===== */}
    <section class="bg-[#1a2a1a] py-24 px-[5vw] relative overflow-hidden max-[640px]:py-16 max-[640px]:px-6" aria-labelledby="cta-heading">
      {/* Decorative circles */}
      <div class="absolute rounded-full pointer-events-none border border-[#2e4a2e]" style="right: -80px; top: -80px; width: 400px; height: 400px;" aria-hidden="true"></div>
      <div class="absolute rounded-full pointer-events-none border border-[#2e4a2e]" style="right: -40px; top: -40px; width: 280px; height: 280px;" aria-hidden="true"></div>

      <div class="relative z-10 max-w-175">
        <div class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#9ab89a] mb-6">
          Próximo paso
        </div>
        <h2
          id="cta-heading"
          class="font-cormorant font-light leading-[1.15] text-[#edf5ed] mb-6"
          style="font-size: clamp(2rem, 4vw, 3.5rem)"
        >
          ¿Querés iniciar tu<br />
          <em class="italic text-[#9ab89a]">proceso terapéutico?</em>
        </h2>
        <p class="text-[0.9rem] font-light text-[#6a8a6a] leading-[1.75] max-w-130 mb-6">
          La terapia cognitivo-conductual cuenta con sólida evidencia en el acompañamiento del embarazo, el posparto y la crianza. Un espacio seguro, sin juicios, para construir una maternidad más consciente y sostenible para tu salud mental.
        </p>
        <blockquote class="border-l-2 border-[#3a5a3a] py-5 pl-7 mb-10">
          <p class="font-cormorant text-[1.1rem] italic font-normal text-[#c4d8c4] leading-[1.6] mb-2">
            "No es necesario estar en crisis para pedir ayuda. Cuidarte es también cuidar a tu familia."
          </p>
          <footer class="text-[0.72rem] font-light tracking-[0.08em] text-[#5a7a5a] uppercase">
            — Psicóloga Amelia Reyes
          </footer>
        </blockquote>
        <a
          href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Salud%20Mental%20Materna"
          class="inline-flex items-center gap-[0.7rem] bg-[#F4F0EC] text-[#1a2a1a] text-[0.78rem] font-medium tracking-[0.12em] uppercase px-9 py-4 no-underline transition-colors duration-250 hover:bg-[#CC8989] hover:text-[#F4F0EC]"
          aria-label="Agendar cita de Salud Mental Materna con Psicóloga Amelia Reyes por WhatsApp"
        >
          Quiero agendar mi cita
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </div>

  <style>
    .font-cormorant { font-family: 'Cormorant Garamond', Georgia, serif; }
    .font-dm-sans   { font-family: 'DM Sans', sans-serif; }

    /* FAQ grid layout */
    .faq-grid {
      grid-template-columns: 280px 1fr;
    }
    @media (max-width: 800px) {
      .faq-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    /* FAQ open state */
    .faq-item.open .faq-answer  { display: block; }
    .faq-item.open button svg   { transform: rotate(45deg); }

    /* Areas grid: 4 cols → 2 cols → 1 col */
    @media (max-width: 1100px) {
      [data-areas-grid] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
      [data-areas-grid] .area-item:nth-child(2n) {
        border-right: none;
      }
    }
    @media (max-width: 640px) {
      [data-areas-grid] {
        grid-template-columns: 1fr !important;
      }
      [data-areas-grid] .area-item {
        border-right: none;
      }
    }
  </style>

  <script>
    document.querySelectorAll('[data-faq]').forEach((item) => {
      const btn = item.querySelector('button');
      btn?.addEventListener('click', () => {
        const isOpen = item.classList.contains('open');
        document.querySelectorAll('[data-faq]').forEach((el) => {
          el.classList.remove('open');
          el.querySelector('button')?.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
</MainLayout>