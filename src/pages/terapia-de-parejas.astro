---
import MainLayout from "@/layouts/MainLayout.astro";
import ameliaProfile from "@/assets/images/couple_therapy.png";

const focusAreas = [
  {
    number: "01",
    title: "Comunicación efectiva",
    description: "Identificar patrones de comunicación que generan conflicto o distancia.",
  },
  {
    number: "02",
    title: "Habilidades relacionales",
    description: "Desarrollar habilidades de comunicación más claras, respetuosas y empáticas.",
  },
  {
    number: "03",
    title: "Creencias y expectativas",
    description: "Trabajar creencias sobre el amor, el compromiso, el rol de cada persona en la relación y las expectativas irreales.",
  },
  {
    number: "04",
    title: "Conexión emocional",
    description: "Fortalecer la conexión emocional y la validación mutua.",
  },
  {
    number: "05",
    title: "Acuerdos realistas",
    description: "Promover acuerdos realistas sobre la convivencia, la crianza, el manejo de conflictos y las necesidades individuales.",
  },
];

const benefits = [
  {
    title: "Mejora la comunicación",
    description: "Aprendés a expresar lo que necesitás sin atacar ni cerrarte, y a escuchar sin ponerte a la defensiva.",
  },
  {
    title: "Reduce conflictos repetitivos",
    description: "Identificás los ciclos que se repiten y construís nuevas formas de responder ante las mismas situaciones.",
  },
  {
    title: "Fortalece la confianza",
    description: "Trabajás la honestidad, la seguridad emocional y la reparación del vínculo cuando ha habido rupturas.",
  },
  {
    title: "Reconexión emocional",
    description: "Recuperás la intimidad, la complicidad y el sentido de equipo que se va perdiendo con el desgaste del día a día.",
  },
  {
    title: "Transforma creencias limitantes",
    description: "Cuestionás ideas rígidas sobre el amor, los roles y las expectativas que generan frustración.",
  },
  {
    title: "Una base más sólida",
    description: "Con herramientas concretas, la pareja desarrolla una forma más consciente y sostenible de relacionarse.",
  },
];

const siteUrl = "https://psicologaameliareyes.com";
const pageUrl = `${siteUrl}/terapia-de-parejas`;
const imageUrl = `${siteUrl}${ameliaProfile.src}`;

const jsonLdService = {
  "@context": "https://schema.org",
  "@type": ["Service", "MedicalBusiness"],
  "name": "Terapia de Pareja en Costa Rica",
  "alternateName": "Terapia de Pareja Online Costa Rica",
  "description": "Terapia de pareja con enfoque cognitivo-conductual en Costa Rica. Mejorá la comunicación, resolvé conflictos y reconectá emocionalmente con tu pareja. Atención presencial en Heredia y sesiones online con la Psicóloga Amelia Reyes.",
  "url": pageUrl,
  "image": imageUrl,
  "provider": {
    "@type": ["Person", "Psychologist"],
    "name": "Amelia Reyes",
    "jobTitle": "Psicóloga Clínica",
    "description": "Psicóloga clínica especializada en terapia de pareja y salud mental en Costa Rica.",
    "url": siteUrl,
    "telephone": "+50660587256",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Heredia",
      "addressCountry": "CR",
    },
    "sameAs": ["https://wa.me/50660587256"],
  },
  "areaServed": [
    { "@type": "Country", "name": "Costa Rica" },
    { "@type": "City", "name": "Heredia" },
    { "@type": "City", "name": "San José" },
  ],
  "serviceType": "Terapia de Pareja",
  "audience": { "@type": "Audience", "audienceType": "Parejas adultas" },
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "CRC",
    "url": "https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Terapia%20de%20Pareja",
  },
};

const jsonLdBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": `${siteUrl}/#servicios` },
    { "@type": "ListItem", "position": 3, "name": "Terapia de Pareja", "item": pageUrl },
  ],
};

const jsonLdFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué es la terapia de pareja cognitivo-conductual?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Es un enfoque terapéutico basado en evidencia que trabaja los pensamientos, emociones y conductas de cada persona para transformar los patrones de interacción que generan conflicto, distancia o desgaste emocional en la relación.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Las sesiones de terapia de pareja son online o presenciales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Cuándo es recomendable buscar terapia de pareja?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se recomienda cuando la pareja experimenta conflictos frecuentes, dificultades de comunicación, desconexión emocional, crisis por infidelidad, problemas de convivencia o cuando desean fortalecer su relación de forma preventiva.",
      },
    },
  ],
};

const title = "Terapia de Pareja en Costa Rica | Psicóloga Amelia Reyes | Heredia y Online";
const description = "Terapia de pareja en Costa Rica con enfoque cognitivo-conductual. Atención presencial en Heredia y sesiones online. Mejorá la comunicación, resolvé conflictos y fortalecé tu relación con la Psicóloga Amelia Reyes.";
---

<MainLayout title={title} description={description} image={ameliaProfile.src}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdService)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdBreadcrumb)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLdFAQ)} />

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap');

    .font-display { font-family: 'Cormorant Garamond', Georgia, serif; }
    .font-body    { font-family: 'DM Sans', sans-serif; }

    /* hero heading fluid size — no Tailwind equivalent for clamp */
    .hero-heading { font-size: clamp(3rem, 6vw, 5.5rem); }
    .cta-heading  { font-size: clamp(2rem, 4vw, 3.5rem); }
    .benefits-heading { font-size: clamp(2rem, 3.5vw, 3rem); }
    .section-title-md { font-size: clamp(1.8rem, 3vw, 2.5rem); }

    /* mix-blend-mode not in Tailwind core */
    .img-blend { mix-blend-mode: luminosity; }

    /* gradient overlay on hero-right */
    .hero-overlay::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #183942 0%, transparent 60%);
      pointer-events: none;
    }

    /* gradient divider */
    .line-divider {
      height: 1px;
      background: linear-gradient(to right, #367588 30%, transparent);
    }

    /* areas grid: 5 cols desktop → 3 → 2 */
    .areas-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      border-top: 1px solid #2a5060;
    }
    @media (max-width: 1100px) { .areas-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 640px)  { .areas-grid { grid-template-columns: repeat(2, 1fr); } }

    .area-item:last-child { border-right: none; }
    @media (max-width: 1100px) { .area-item:nth-child(3n) { border-right: none; } }
    @media (max-width: 640px)  { .area-item:nth-child(2n) { border-right: none; } }

    /* benefits grid: 3 cols → 2 → 1 */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid #d9d3cc;
      border-left: 1px solid #d9d3cc;
    }
    @media (max-width: 900px) { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .benefits-grid { grid-template-columns: 1fr; } }

    /* FAQ open state */
    .faq-item.open .faq-icon { transform: rotate(45deg); }
    .faq-item .faq-answer    { display: none; }
    .faq-item.open .faq-answer { display: block; }

    /* CTA decorative circles */
    .cta-deco   { position: absolute; right: -80px; top: -80px; width: 400px; height: 400px; border: 1px solid #2a5060; border-radius: 50%; pointer-events: none; }
    .cta-deco-2 { position: absolute; right: -40px; top: -40px; width: 280px; height: 280px; border: 1px solid #2a5060; border-radius: 50%; pointer-events: none; }
  </style>

  <div class="font-body bg-[#F4F0EC] text-[#183942]">

    <!-- ===== HERO ===== -->
    <section
      class="grid grid-cols-1 md:grid-cols-2 relative overflow-hidden min-h-130 lg:min-h-130"
      aria-label="Terapia de Pareja en Costa Rica"
    >
      <!-- Left -->
      <div class="flex flex-col justify-center px-[5vw] pr-12 py-24 md:py-24 relative z-10">

        <!-- Breadcrumb -->
        <nav aria-label="Ruta de navegación" class="flex items-center gap-2 text-xs text-[#8aabb3] mb-8">
          <a href="/" class="hover:text-[#183942] transition-colors no-underline">Inicio</a>
          <span class="text-[#ccc]">/</span>
          <a href="/#servicios" class="hover:text-[#183942] transition-colors no-underline">Servicios</a>
          <span class="text-[#ccc]">/</span>
          <span class="text-[#183942] font-medium" aria-current="page">Terapia de Pareja</span>
        </nav>

        <!-- Tag -->
        <span class="inline-block text-[0.7rem] font-medium tracking-[0.18em] uppercase text-[#367588] border border-[#367588] px-[0.9rem] py-[0.35rem] rounded-sm mb-8 w-fit">
          Servicio especializado
        </span>

        <!-- Heading -->
        <h1 class="font-display hero-heading font-light leading-[1.05] text-[#183942] m-0 mb-7">
          Terapia de<br/>
          <em class="italic text-[#367588]">Pareja</em><br/>
          <span class="text-[0.75em] text-[#183942]">en Costa Rica</span>
        </h1>

        <!-- Sub -->
        <p class="text-base font-light text-[#4a6068] leading-[1.7] max-w-110 mb-12">
          Un espacio para comprender y transformar los patrones que generan distancia, conflicto o desgaste emocional. Presencial en <strong class="font-medium text-[#183942]">Heredia</strong> y <strong class="font-medium text-[#183942]">online</strong> para toda Costa Rica.
        </p>

        <!-- Actions -->
        <div class="flex items-center gap-8 flex-wrap">
          <a
            href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Terapia%20de%20Pareja"
            class="inline-flex items-center gap-2 bg-[#183942] text-[#F4F0EC] text-[0.8rem] font-medium tracking-widest uppercase px-8 py-4 no-underline transition-colors duration-300 hover:bg-[#367588]"
            aria-label="Agendar cita de Terapia de Pareja por WhatsApp"
          >
            Agenda tu cita
            <svg class="w-3.5 h-3.5 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="#como-funciona" class="text-[0.8rem] font-normal tracking-[0.08em] text-[#367588] no-underline border-b border-[#367588] pb-0.5 transition-opacity hover:opacity-65">
            Cómo funciona
          </a>
        </div>
      </div>

      <!-- Right (image) -->
      <div class="relative bg-[#183942] overflow-hidden hero-overlay max-md:h-[65vw] max-md:min-h-[80" aria-hidden="true">
        <img
          src={ameliaProfile.src}
          alt=""
          width={ameliaProfile.width}
          height={ameliaProfile.height}
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover object-top opacity-55 img-blend max-md:object-position:[center_20%]"
        />
      </div>
    </section>

    <!-- Divider -->
    <div class="line-divider"></div>

    <!-- ===== CÓMO FUNCIONA ===== -->
    <section id="como-funciona" class="px-[5vw] py-20 max-sm:px-6 max-sm:py-14" aria-labelledby="enfoque-heading">

      <p class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#367588] mb-5">Enfoque terapéutico</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-0 mt-16">

        <!-- Left col -->
        <div class="pr-16 border-r border-[#d9d3cc] max-md:pr-0 max-md:border-r-0 max-md:border-b max-md:border-[#d9d3cc] max-md:pb-12 max-md:mb-12">
          <h2 id="enfoque-heading" class="font-display section-title-md font-normal leading-[1.15] text-[#183942] mb-7">
            ¿Cómo funciona la terapia de pareja cognitivo-conductual?
          </h2>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            Desde un enfoque cognitivo-conductual, se parte de la idea de que los pensamientos, las emociones y las conductas de cada persona influyen en la dinámica de la pareja. No solo importa lo que ocurre entre dos personas, sino cómo cada una interpreta lo que ocurre y cómo responde ante eso.
          </p>
          <p class="text-base font-light text-[#4a6068] leading-[1.8] mb-6">
            Las investigaciones muestran que muchas dificultades de pareja se mantienen por ciclos repetitivos: críticas, defensividad, silencios, reproches o intentos de control que, aunque buscan proteger, terminan aumentando la desconexión emocional.
          </p>
          <!-- Blockquote -->
          <blockquote class="border-l-2 border-[#367588] pl-8 py-6 mt-10">
            <p class="font-display text-[1.25rem] italic font-normal text-[#183942] leading-[1.55] mb-3">
              "No se trata de buscar culpables, sino de ayudar a la pareja a ver los ciclos que se repiten, entender qué los mantiene y construir nuevas formas de vincularse más sanas y conscientes."
            </p>
            <footer class="text-[0.75rem] font-light tracking-[0.08em] text-[#8aabb3] uppercase">— Psicóloga Amelia Reyes</footer>
          </blockquote>
        </div>

        <!-- Right col -->
        <div class="pl-16 max-md:pl-0">
          <h3 class="font-display text-[1.4rem] font-medium text-[#183942] mb-6">¿Cuándo buscar terapia de pareja?</h3>
          <ul class="list-none p-0 m-0" role="list">
            {[
              "Conflictos frecuentes sin resolución o con escalada emocional",
              "Distancia emocional, frialdad o sensación de vivir como compañeros de cuarto",
              "Crisis por infidelidad, pérdida de confianza o traición",
              "Dificultades en la convivencia, crianza o toma de decisiones conjuntas",
              "Deseo de fortalecer la relación de forma preventiva",
            ].map((item, i) => (
              <li class="flex items-start gap-4 py-[0.9rem] border-b border-[#e8e2db] last:border-b-0 text-[0.9rem] font-light text-[#4a6068] leading-normal">
                <span class="font-display text-[0.85rem] text-[#367588] italic shrink-0 pt-px">
                  {String(i + 1).padStart(2, "0")}.
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ===== ÁREAS DE ENFOQUE (dark) ===== -->
    <section class="bg-[#183942] px-[5vw] py-20 max-sm:px-6 max-sm:py-14" aria-labelledby="areas-heading">

      <div class="flex items-end justify-between gap-8 mb-14 flex-wrap">
        <div>
          <p class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#6fa8b8] mb-5">Trabajo terapéutico</p>
          <h2 id="areas-heading" class="font-display section-title-md font-normal leading-[1.15] text-[#F4F0EC]">
            Áreas de enfoque
          </h2>
        </div>
        <p class="text-[0.9rem] font-light text-[#8aabb3] max-w-[320px] leading-[1.6]">
          El proceso terapéutico trabaja sobre estas dimensiones fundamentales de la relación.
        </p>
      </div>

      <div class="areas-grid" role="list">
        {focusAreas.map((area) => (
          <div class="area-item px-6 py-8 border-r border-b border-[#2a5060]" role="listitem">
            <span class="font-display text-[0.9rem] italic text-[#367588] mb-5 block">{area.number}</span>
            <div class="text-[0.85rem] font-medium text-[#d4e8ed] mb-3 leading-[1.3]">{area.title}</div>
            <p class="text-[0.78rem] font-light text-[#6a8e98] leading-[1.65]">{area.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== BENEFICIOS ===== -->
    <section class="bg-[#F4F0EC] px-[5vw] py-20 max-sm:px-6 max-sm:py-14" aria-labelledby="benefits-heading">

      <div class="max-w-130 mb-16">
        <p class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#367588] mb-5">Resultados</p>
        <h2 id="benefits-heading" class="font-display benefits-heading font-normal leading-[1.15] text-[#183942] mb-3">
          ¿Qué cambia con<br/> la terapia de pareja?
        </h2>
        <p class="text-[0.85rem] font-light text-[#4a6068] leading-[1.6] mt-4">
          La evidencia científica respalda sus beneficios. Estos son los cambios más frecuentes que experimentan las parejas durante el proceso.
        </p>
      </div>

      <div class="benefits-grid">
        {benefits.map((b) => (
          <div class="p-8 border-r border-b border-[#d9d3cc]">
            <h3 class="font-display text-[1.15rem] font-medium text-[#183942] mb-3 leading-[1.3]">{b.title}</h3>
            <p class="text-[0.83rem] font-light text-[#4a6068] leading-[1.7]">{b.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ===== LOCAL STRIP ===== -->
    <div class="bg-[#eae5df] px-[5vw] py-10 flex items-center gap-8 flex-wrap max-sm:px-6 max-sm:py-8 max-sm:gap-4" aria-label="Disponibilidad">
      <span class="text-[0.68rem] font-medium tracking-[0.18em] uppercase text-[#367588] shrink-0">
        Heredia · Online · Costa Rica
      </span>
      <div class="flex-1 h-px bg-[#d9d3cc]" aria-hidden="true"></div>
      <p class="text-[0.83rem] font-light text-[#4a6068] leading-[1.65] max-w-160">
        Si buscás terapia de pareja en Heredia, ofrezco atención presencial en consultorio y sesiones online para todo el país. Confidencialidad, respeto y acompañamiento profesional en cada etapa de la relación.
      </p>
    </div>

    <!-- ===== FAQ ===== -->
    <section class="bg-white px-[5vw] py-20 max-sm:px-6 max-sm:py-14" aria-labelledby="faq-heading">
      <div class="grid grid-cols-1 md:grid-template-cols-[280px_1fr] gap-16 items-start max-md:gap-8">

        <div>
          <p class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#367588] mb-5">FAQ</p>
          <h2 id="faq-heading" class="font-display section-title-md font-normal leading-[1.15] text-[#183942]">
            Preguntas frecuentes
          </h2>
        </div>

        <dl class="border-t border-[#e8e2db]">
          {[
            {
              q: "¿Qué es la terapia de pareja cognitivo-conductual?",
              a: "Es un enfoque terapéutico basado en evidencia que trabaja los pensamientos, emociones y conductas de cada persona para transformar los patrones de interacción que generan conflicto, distancia o desgaste emocional en la relación.",
            },
            {
              q: "¿Las sesiones son online o presenciales?",
              a: "Ofrezco sesiones tanto online (para cualquier parte de Costa Rica y el exterior) como presenciales en Heredia, Costa Rica. La modalidad se acuerda según lo que mejor se adapte a cada pareja.",
            },
            {
              q: "¿Cuándo es recomendable buscar terapia de pareja?",
              a: "Se recomienda cuando la pareja experimenta conflictos frecuentes, dificultades de comunicación, desconexión emocional, crisis por infidelidad, problemas de convivencia o cuando desean fortalecer su relación de forma preventiva.",
            },
          ].map((item) => (
            <div class="faq-item border-b border-[#e8e2db]" data-faq>
              <button
                class="faq-q w-full bg-transparent border-none py-6 flex items-center justify-between gap-4 cursor-pointer text-left font-body text-[0.9rem] font-medium text-[#183942] leading-[1.4]"
                aria-expanded="false"
              >
                <span>{item.q}</span>
                <svg class="faq-icon shrink-0 w-4 h-4 text-[#367588] transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
              </button>
              <dd class="faq-answer pb-6 text-[0.85rem] font-light text-[#4a6068] leading-[1.75]">{item.a}</dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="bg-[#183942] px-[5vw] py-24 relative overflow-hidden max-sm:px-6 max-sm:py-16" aria-labelledby="cta-heading">
      <div class="cta-deco" aria-hidden="true"></div>
      <div class="cta-deco-2" aria-hidden="true"></div>

      <div class="relative z-10 max-w-175">
        <p class="text-[0.68rem] font-medium tracking-[0.2em] uppercase text-[#6fa8b8] mb-6">Próximo paso</p>
        <h2 id="cta-heading" class="font-display cta-heading font-light leading-[1.15] text-[#F4F0EC] mb-6">
          ¿Querés mejorar<br/>
          tu <em class="italic text-[#6fa8b8]">relación de pareja?</em>
        </h2>
        <p class="text-[0.9rem] font-light text-[#8aabb3] leading-[1.75] max-w-130 mb-12">
          La terapia cognitivo-conductual en pareja cuenta con amplia evidencia en la reducción del conflicto, el aumento de la satisfacción relacional y la mejora en la resolución de problemas. No se trata de buscar culpables, sino de construir nuevas formas de vincularse.
        </p>
        <a
          href="https://wa.me/50660587256?text=Hola%20Amelia%2C%20me%20interesa%20el%20servicio%20de%20Terapia%20de%20Pareja"
          class="inline-flex items-center gap-3 bg-[#F4F0EC] text-[#183942] text-[0.78rem] font-medium tracking-[0.12em] uppercase px-9 py-4 no-underline transition-colors duration-300 hover:bg-[#367588] hover:text-[#F4F0EC]"
